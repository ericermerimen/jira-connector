#!/usr/bin/env bash
set -euo pipefail

_cleanup_files=()
cleanup() { [[ ${#_cleanup_files[@]} -gt 0 ]] && rm -f "${_cleanup_files[@]}"; return 0; }
trap cleanup EXIT

# jira-api: Authenticated Jira REST API wrapper with retry
# Usage:
#   jira-api <endpoint>                          # GET request
#   jira-api <endpoint> -X POST -d '{"json":1}'  # POST request
#   jira-api <endpoint> [any curl args...]        # Pass-through
#
# Exit codes:
#   0 = success
#   1 = auth fail / not found / other
#   3 = timeout
#   4 = 403 forbidden
#   5 = no credentials

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

MAX_RETRIES=3
INITIAL_BACKOFF=2

main() {
    local endpoint="${1:-}"
    [[ -z "$endpoint" ]] && { echo "Usage: jira-api <endpoint> [curl-args...]"; exit 1; }
    shift

    # Remove leading slash if present
    endpoint="${endpoint#/}"

    local url email token
    url="$("$SCRIPT_DIR/jira-config" get jira_url 2>/dev/null)" || true
    email="$("$SCRIPT_DIR/jira-config" get jira_email 2>/dev/null)" || true
    token="$("$SCRIPT_DIR/jira-cred" get token 2>/dev/null)" || {
        echo "ERROR: Could not retrieve Jira token" >&2
        exit 5
    }

    [[ -z "$url" ]] && { echo "ERROR: jira_url not configured" >&2; exit 1; }
    [[ -z "$email" ]] && { echo "ERROR: jira_email not configured" >&2; exit 1; }

    local full_url="${url}/${endpoint}"
    local attempt=0
    local backoff=$INITIAL_BACKOFF

    # Add --ssl-no-revoke for Windows environments
    local curl_opts=()
    local env
    env="$("$SCRIPT_DIR/jira-cred" detect-env)"
    if [[ "$env" == windows-* ]]; then
        curl_opts+=(--ssl-no-revoke)
    fi

    # Detect file upload (-F flag) — skip Content-Type so curl sets multipart/form-data
    local has_file_upload=false
    for arg in "$@"; do
        [[ "$arg" == "-F" || "$arg" == --form || "$arg" == --form=* ]] && has_file_upload=true
    done

    local content_type_args=()
    if [[ "$has_file_upload" == false ]]; then
        content_type_args+=(-H "Content-Type: application/json")
    fi

    while [[ $attempt -le $MAX_RETRIES ]]; do
        local tmpfile http_code
        tmpfile="$(mktemp)"
        _cleanup_files+=("$tmpfile")

        http_code="$(printf -- '-u %s:%s\n' "$email" "$token" | curl --config - \
            -s -w "%{http_code}" -o "$tmpfile" \
            --connect-timeout 10 \
            "${curl_opts[@]}" \
            -H "Accept: application/json" \
            "${content_type_args[@]}" \
            "$@" \
            "$full_url" 2>/dev/null)" || {
            echo "ERROR: Network timeout" >&2
            exit 3
        }

        case "$http_code" in
            2*)
                cat "$tmpfile"
                return 0
                ;;
            429)
                if [[ $attempt -lt $MAX_RETRIES ]]; then
                    echo "Rate limited. Retrying in ${backoff}s... (attempt $((attempt + 1))/$MAX_RETRIES)" >&2
                    sleep "$backoff"
                    backoff=$((backoff * 2))
                    attempt=$((attempt + 1))
                else
                    echo "ERROR: Rate limited after $MAX_RETRIES retries" >&2
                    exit 1
                fi
                ;;
            401)
                echo "ERROR: Authentication failed (401)" >&2
                exit 1
                ;;
            403)
                echo "ERROR: Access denied (403)" >&2
                exit 4
                ;;
            404)
                echo "ERROR: Not found (404)" >&2
                exit 1
                ;;
            *)
                local body
                body="$(cat "$tmpfile")"
                echo "ERROR: HTTP $http_code: $body" >&2
                exit 1
                ;;
        esac
    done
}

main "$@"
