#!/usr/bin/env bash
set -euo pipefail

_cleanup_files=()
cleanup() { rm -f "${_cleanup_files[@]}"; }
trap cleanup EXIT

# jira-config: Read, write, and validate ~/.jira-connector/config.yaml
# Usage:
#   jira-config get <key>              # Read a top-level key
#   jira-config get-nested <path>      # Read nested key (e.g., workflows.Bug.transition_to)
#   jira-config set <key> <value>      # Write a top-level key
#   jira-config validate               # Validate config, exit 0 if valid, 1 if not
#   jira-config resolve                # Print merged config (global + per-project)
#   jira-config path                   # Print path to global config file
#   jira-config version                # Print version, config path, credential method, projects

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GLOBAL_CONFIG="$HOME/.jira-connector/config.yaml"
PROJECT_CONFIG=""

# Find per-project config by walking up to git root
find_project_config() {
    local git_root
    git_root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 1
    if [[ -f "$git_root/.jira-connector.yaml" ]]; then
        echo "$git_root/.jira-connector.yaml"
    fi
}

# Read a value from YAML using jq-compatible yq or basic grep/sed
# We use jq on a YAML-to-JSON conversion approach
# Since we can't assume yq, we parse simple YAML with sed+grep
read_yaml_key() {
    local file="$1"
    local key="$2"
    if [[ ! -f "$file" ]]; then
        return 1
    fi
    # Simple top-level key extraction (handles: key: value, key: "value")
    while IFS= read -r line; do
        if [[ "$line" == "${key}:"* ]]; then
            printf '%s\n' "$line" | sed -E 's/^[^:]+:[[:space:]]*//' | sed -E 's/^["'"'"']|["'"'"']$//g' | sed -E 's/[[:space:]]*$//'
            return
        fi
    done < "$file"
}

# Read nested key like workflows.Bug.transition_to
read_yaml_nested() {
    local file="$1"
    local path="$2"
    # For nested keys, use a simple state machine approach
    # Split path by dots
    local IFS='.'
    local parts
    read -ra parts <<< "$path"

    if [[ ${#parts[@]} -eq 1 ]]; then
        read_yaml_key "$file" "${parts[0]}"
        return
    fi

    # For deeper nesting, extract the block and parse
    # This handles 2-3 level nesting which is all we need
    local in_block=0
    local indent=""
    local target_key="${parts[0]}"
    local remaining="${path#*.}"

    local block=""
    while IFS= read -r line; do
        if [[ $in_block -eq 0 ]]; then
            if [[ "$line" == "${target_key}:"* ]]; then
                in_block=1
                indent=""
            fi
        elif [[ $in_block -eq 1 ]]; then
            if [[ -z "$indent" ]]; then
                indent="$(echo "$line" | sed -E 's/^( +).*/\1/')"
                if [[ -z "$indent" ]] || ! echo "$line" | grep -qE '^[[:space:]]'; then
                    break
                fi
            fi
            if echo "$line" | grep -qE "^${indent}[^ ]"; then
                block+="$(echo "$line" | sed -E "s/^${indent}//")"$'\n'
            elif echo "$line" | grep -qE "^${indent} "; then
                block+="$(echo "$line" | sed -E "s/^${indent}//")"$'\n'
            else
                break
            fi
        fi
    done < "$file"

    if [[ -n "$block" ]]; then
        # Recursively parse the remaining path in the extracted block
        local tmpfile
        tmpfile="$(mktemp)"
        _cleanup_files+=("$tmpfile")
        echo "$block" > "$tmpfile"
        read_yaml_nested "$tmpfile" "$remaining"
    fi
}

# Write a top-level key to config (atomic write)
write_yaml_key() {
    local file="$1"
    local key="$2"
    local value="$3"

    mkdir -p "$(dirname "$file")"

    if [[ ! -f "$file" ]]; then
        local newfile
        newfile="$(mktemp)"
        _cleanup_files+=("$newfile")
        echo "${key}: ${value}" > "$newfile"
        chmod 600 "$newfile" 2>/dev/null || true
        mv "$newfile" "$file"
        return
    fi

    local tmpfile
    tmpfile="$(mktemp)"
    _cleanup_files+=("$tmpfile")
    local found=0
    while IFS= read -r line; do
        if [[ "$line" == "${key}:"* ]]; then
            found=1
        fi
    done < "$file"
    if [[ $found -eq 1 ]]; then
        while IFS= read -r line; do
            if [[ "$line" == "${key}:"* ]]; then
                printf '%s\n' "${key}: ${value}"
            else
                printf '%s\n' "$line"
            fi
        done < "$file" > "$tmpfile"
    else
        cp "$file" "$tmpfile"
        echo "${key}: ${value}" >> "$tmpfile"
    fi
    chmod 600 "$tmpfile" 2>/dev/null || true
    mv "$tmpfile" "$file"
}

# Validate config values
validate_config() {
    local file="$1"
    local errors=0

    if [[ ! -f "$file" ]]; then
        echo "ERROR: Config file not found: $file" >&2
        return 1
    fi

    # Validate jira_url
    local url
    url="$(read_yaml_key "$file" "jira_url")"
    if [[ -n "$url" ]]; then
        if ! echo "$url" | grep -qE '^https://[a-zA-Z0-9.-]+\.atlassian\.net$'; then
            echo "ERROR: jira_url must match https://*.atlassian.net (got: $url)" >&2
            errors=$((errors + 1))
        fi
    fi

    # Validate jira_email
    local email
    email="$(read_yaml_key "$file" "jira_email")"
    if [[ -n "$email" ]]; then
        if ! echo "$email" | grep -qE '^[^@]+@[^@]+$'; then
            echo "ERROR: jira_email must be a valid email (got: $email)" >&2
            errors=$((errors + 1))
        fi
        # Check for shell metacharacters
        if echo "$email" | grep -qE '[;|&$`\\(){}]'; then
            echo "ERROR: jira_email contains shell metacharacters" >&2
            errors=$((errors + 1))
        fi
    fi

    # Validate credential_method
    local cred_method
    cred_method="$(read_yaml_key "$file" "credential_method")"
    if [[ -n "$cred_method" ]]; then
        if [[ "$cred_method" != "keychain" && "$cred_method" != "env" ]]; then
            echo "ERROR: credential_method must be 'keychain' or 'env' (got: $cred_method)" >&2
            errors=$((errors + 1))
        fi
    fi

    # Validate docs_path (no absolute, no traversal)
    local docs_path
    docs_path="$(read_yaml_key "$file" "docs_path")"
    if [[ -n "$docs_path" ]]; then
        if [[ "$docs_path" == /* ]]; then
            echo "ERROR: docs_path must be relative (got: $docs_path)" >&2
            errors=$((errors + 1))
        fi
        if echo "$docs_path" | grep -qE '\.\.'; then
            echo "ERROR: docs_path must not contain '..' (got: $docs_path)" >&2
            errors=$((errors + 1))
        fi
    fi

    if [[ $errors -gt 0 ]]; then
        echo "Validation failed with $errors error(s)" >&2
        return 1
    fi

    echo "Config valid"
    return 0
}

# Merge per-project config over global (only allowed keys)
# NOTE: Only top-level scalar values are merged. Block values like workflows are not merged from per-project config.
resolve_config() {
    local project_config
    project_config="$(find_project_config)" || true

    if [[ -z "$project_config" ]] || [[ ! -f "$project_config" ]]; then
        cat "$GLOBAL_CONFIG"
        return
    fi

    # Allowed override keys
    local allowed_keys="jira_url jira_email workflows docs_path ticket_prefixes projects"

    # Start with global config
    local tmpfile
    tmpfile="$(mktemp)"
    _cleanup_files+=("$tmpfile")
    cp "$GLOBAL_CONFIG" "$tmpfile"

    for key in $allowed_keys; do
        local val
        val="$(read_yaml_key "$project_config" "$key")" || true
        if [[ -n "$val" ]]; then
            write_yaml_key "$tmpfile" "$key" "$val"
        fi
    done

    cat "$tmpfile"
}

# Print version and diagnostics
show_version() {
    local plugin_json=""
    # Walk up from script dir to find plugin.json
    local search_dir="$SCRIPT_DIR"
    while [[ "$search_dir" != "/" ]]; do
        if [[ -f "$search_dir/.claude-plugin/plugin.json" ]]; then
            plugin_json="$search_dir/.claude-plugin/plugin.json"
            break
        fi
        search_dir="$(dirname "$search_dir")"
    done
    if [[ -z "$plugin_json" ]]; then
        echo "ERROR: Cannot find plugin.json" >&2
        exit 1
    fi
    local ver
    ver="$(grep '"version"' "$plugin_json" | head -1 | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/')"
    echo "jira-connector v${ver}"
    echo "Config: $GLOBAL_CONFIG"
    local cred_method
    cred_method="$(read_yaml_key "$GLOBAL_CONFIG" "credential_method" 2>/dev/null || echo "not configured")"
    echo "Credentials: ${cred_method:-not configured}"
    local projects
    projects="$(read_yaml_key "$GLOBAL_CONFIG" "projects" 2>/dev/null || echo "")"
    if [[ -n "$projects" && "$projects" != "[]" ]]; then
        echo "Projects: $projects"
    else
        echo "Projects: none"
    fi
}

# Main command dispatch
case "${1:-}" in
    get)
        [[ -z "${2:-}" ]] && { echo "Usage: jira-config get <key>"; exit 1; }
        read_yaml_key "$GLOBAL_CONFIG" "$2"
        ;;
    get-nested)
        [[ -z "${2:-}" ]] && { echo "Usage: jira-config get-nested <path>"; exit 1; }
        read_yaml_nested "$GLOBAL_CONFIG" "$2"
        ;;
    set)
        [[ -z "${2:-}" || -z "${3:-}" ]] && { echo "Usage: jira-config set <key> <value>"; exit 1; }
        write_yaml_key "$GLOBAL_CONFIG" "$2" "$3"
        ;;
    validate)
        validate_config "$GLOBAL_CONFIG"
        ;;
    resolve)
        resolve_config
        ;;
    path)
        echo "$GLOBAL_CONFIG"
        ;;
    version)
        show_version
        ;;
    *)
        echo "Usage: jira-config {get|get-nested|set|validate|resolve|path|version} [args]"
        exit 1
        ;;
esac
